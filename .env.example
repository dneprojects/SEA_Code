# Copy to ".env" and adjust. Used by docker-compose.yml.

# Websocket URL of your Home Assistant instance.
# Same compose network:   ws://homeassistant:8123/api/websocket
# HA on the docker host:   ws://host.docker.internal:8123/api/websocket
# HA on a fixed IP:        ws://192.168.178.144:8123/api/websocket
HA_URL=ws://192.168.178.111:8123/api/websocket

# Long-lived access token from HA: profile page -> "Long-lived access tokens".
# NEVER commit a real token. Keep it only in your local, untracked .env.
HA_TOKEN=

# Optional
EA_LOG_LEVEL=info
EA_HISTORY_DAYS=90
